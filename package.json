{
  "name": "esp32-cam-streaming-provider",
  "version": "1.0.0",
  "description": "Multi-User ESP32-CAM Streaming Provider with API Key System",
  "main": "server/index.js",
  "scripts": {
    "dev": "nodemon server/index.js",
    "start": "node server/index.js",
    "setup": "node server/setup-db.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop esp32-cam-streaming",
    "pm2:restart": "pm2 restart esp32-cam-streaming",
    "pm2:delete": "pm2 delete esp32-cam-streaming",
    "pm2:logs": "pm2 logs esp32-cam-streaming",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status"
  },
  "keywords": ["esp32", "cam", "streaming", "api", "nodejs"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "@supabase/supabase-js": "^2.38.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}

